<script>
(function(){
if(window.__carouselBillingChecked)return;
window.__carouselBillingChecked=true;
function h(){var e=document.querySelectorAll('[data-carousel-billing-gate]');for(var i=0;i<e.length;i++)e[i].style.display='none'}
fetch('/apps/carousel/billing-status').then(function(r){return r.json()}).then(function(d){if(d&&d.active===false)h()}).catch(h);
})();
</script>
