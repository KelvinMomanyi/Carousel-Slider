{% render 'billing-gate' %}
{%- liquid
  assign carousel_billing_value = shop.metafields["app--carousel-slider"].billing_active.value
  assign carousel_billing_expires_at = shop.metafields["app--carousel-slider"].billing_access_expires_at.value
  assign carousel_billing_now = 'now' | date: '%s' | plus: 0
  assign carousel_billing_expires = carousel_billing_expires_at | date: '%s' | plus: 0
  assign carousel_billing_active = false

  if carousel_billing_value == true or carousel_billing_value == 'true'
    if carousel_billing_expires > carousel_billing_now
      assign carousel_billing_active = true
    endif
  endif
-%}
{%- if carousel_billing_active -%}
{% liquid
assign section_id = 'slider-11-' | append: block.id
if block.settings.selected_collection != blank
assign slider_collection = collections[block.settings.selected_collection]
else
assign slider_collection = collections.all
endif
assign products_limit = block.settings.products_limit | default: 6
assign products_display_mode = block.settings.products_display_mode | default: 'limited'
assign products_to_show = products_limit
if products_display_mode == 'all'
assign products_to_show = slider_collection.products_count | default: slider_collection.products.size
endif
%}
{% if slider_collection != blank and slider_collection.products_count > 0 %}
{{ 'slider-11-cards.css' | asset_url | stylesheet_tag }}
<script src="{{ 'slider-11-cards.js' | asset_url }}" defer></script>
<div id="{{ section_id }}" class="slider-11-root gradient{% if block.settings.text_color != blank %} has-slider-text-color{% endif %}{% if block.settings.text_font_size != blank %} has-slider-text-size{% endif %}{% if block.settings.button_color != blank %} has-slider-button-color{% endif %}{% if block.settings.button_text_color != blank %} has-slider-button-text-color{% endif %}{% if block.settings.button_font_size != blank %} has-slider-button-size{% endif %}" data-carousel-billing-gate style="
--slider-11-height: {{ block.settings.section_height }};
{% if block.settings.text_color != blank %}--slider-style-text-color: {{ block.settings.text_color }};{% endif %}
{% if block.settings.text_font_size != blank %}--slider-style-text-size: {{ block.settings.text_font_size }};{% endif %}
{% if block.settings.button_color != blank %}--slider-style-button-color: {{ block.settings.button_color }};{% endif %}
{% if block.settings.button_text_color != blank %}--slider-style-button-text-color: {{ block.settings.button_text_color }};{% endif %}
{% if block.settings.button_font_size != blank %}--slider-style-button-size: {{ block.settings.button_font_size }};{% endif %}
" data-slider-11 {{ block.shopify_attributes }}>
<div class="container">
<div id="slide-{{ block.id }}" data-slider-11-track>
{% for product in slider_collection.products limit: products_to_show %}
{% assign active_variant = product.selected_or_first_available_variant %}
<div class="item" style="background-image: url('{{ product.featured_image | image_url: width: 1600 }}');">
<div class="content">
<div class="name">{{ product.title | escape }}</div>
<div class="price">
{% if active_variant.compare_at_price > active_variant.price %}
<span class="compare">{{ active_variant.compare_at_price | money_with_currency }}</span>
{% endif %}
<span>{{ active_variant.price | money_with_currency }}</span>
</div>
<div class="actions">
<button class="add-to-cart" type="button" data-cart-id="{{ active_variant.id }}"{% unless active_variant.available %} disabled{% endunless %}>{% if active_variant.available %}Add to cart{% else %}Sold out{% endif %}</button>
<p class="cart-feedback" aria-live="polite"></p>
</div>
</div>
</div>
{% endfor %}
</div>
<div class="buttons">
<button id="prev-{{ block.id }}" type="button" aria-label="Previous slide" data-slider-11-prev>&#8249;</button>
<button id="next-{{ block.id }}" type="button" aria-label="Next slide" data-slider-11-next>&#8250;</button>
</div>
</div>
</div>
{% else %}
<div class="slider-liquid-empty" {{ block.shopify_attributes }}>Select a collection with products to render this slider.</div>
{% endif %}
{%- endif -%}

{% schema %}
{"name":"Carousel: Coverflow","settings":[{"type":"collection","id":"selected_collection","label":"Collection"},{"type":"select","id":"products_display_mode","label":"Products to show","options":[{"value":"limited","label":"Set number"},{"value":"all","label":"All products"}],"default":"limited"},{"type":"range","id":"products_limit","label":"Number of products","min":3,"max":10,"step":1,"default":6},{"type":"text","id":"section_height","label":"Section height","default":"700px"},{"type":"header","content":"Text and Button Styling"},{"type":"color","id":"text_color","label":"Text color"},{"type":"text","id":"text_font_size","label":"Text font size","info":"Use a CSS size, for example 18px or 1.2rem."},{"type":"color","id":"button_color","label":"Button color"},{"type":"color","id":"button_text_color","label":"Button text color"},{"type":"text","id":"button_font_size","label":"Button font size","info":"Use a CSS size, for example 16px or 1rem."}],"target":"section"}
{% endschema %}
